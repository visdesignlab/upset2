{
  "name": "@visdesignlab/upset2-core",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visdesignlab/upset2.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "typings": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {},
  "husky": {
    "hooks": {
      "pre-commit": "yarn lint"
    }
  },
  "author": "Kiran Gadhave (kirangadhave2@gmail.com), Jake Wagoner, Nate Lanza",
  "devDependencies": {
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^7.0.4",
    "prettier": "^3.5.3",
    "tslib": "^2.3.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "hyperid": "^3.0.0"
  }
}
